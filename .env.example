# ── DB-Architect Configuration ───────────────────────────
# Copy this file to .env and fill in your values.

# Your OpenAI (or Gemini via LiteLLM) API key
OPENAI_API_KEY=sk-your-key-here

# LLM model to use (default: gpt-4o-mini)
# Examples: gpt-4o, gpt-4o-mini, gemini/gemini-2.0-flash
MODEL=gpt-4o-mini

# Maximum reflection loop iterations before aborting (default: 5)
MAX_REFLECTION_RETRIES=5
